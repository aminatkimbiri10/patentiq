NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Logo I2PA — par défaut : wordmark typographique intégré (sidebar claire)
# Pour le PNG officiel (fond noir retiré visuellement sur fond clair) :
# NEXT_PUBLIC_ORG_LOGO_URL=/logos/i2pa.png
# NEXT_PUBLIC_ORG_NAME=I2PA

# Secret pour POST /api/ai/worker et /api/surveillance/worker (cron)
AI_WORKER_SECRET=change-me-in-production
# Optionnel : secret dédié surveillance (sinon réutilise AI_WORKER_SECRET)
# SURVEILLANCE_WORKER_SECRET=

# --- Surveillance OMPIC (voir docs/OMPIC_SURVEILLANCE.md) ---
# live (défaut prod) | stub | proxy | hybrid — **hybrid recommandé** (dessins + démo)
OMPIC_SEARCH_MODE=hybrid
# URL complète webhook n8n (ex. https://xxx.app.n8n.cloud/webhook/ompic-search)
# OMPIC_PROXY_URL=
# OMPIC_PROXY_TOKEN=

# --- Recherche brevets / veille (EPO OPS — https://developers.epo.org) ---
EPO_OPS_CONSUMER_KEY=
EPO_OPS_CONSUMER_SECRET=
# Hugging Face — https://huggingface.co/settings/tokens (tier gratuit)
HUGGINGFACE_API_KEY=
# HUGGINGFACE_MODEL=Qwen/Qwen2.5-7B-Instruct

# --- Emails transactionnels (Resend — https://resend.com) ---
# Sans RESEND_API_KEY : notifications in-app uniquement (log console)
# RESEND_API_KEY=re_xxxxxxxx
# EMAIL_FROM=PatentIQ <noreply@votredomaine.com>
